# Example environment variables for Alumni Connect

# Backend
PORT=3000
MONGO_URI=mongodb://localhost:27017/alumni_connect
JWT_SECRET=replace_with_a_strong_secret

# Admin credentials (optional): if provided, server will create an admin user on startup
# WARNING: Do NOT commit real secrets to git. Use your local `.env` for real values.
ADMIN_NAME=Main Admin
ADMIN_EMAIL=admin@alumni.com
ADMIN_PASSWORD=admin123

# Frontend (Vite variables are prefixed with VITE_ to be exposed to client)
VITE_API_BASE=http://localhost:3000
